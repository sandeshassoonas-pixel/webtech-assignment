using System;

class Program
{
    static void Main()
    {
        int[][] numbers = new int[3][];

        numbers[0] = new int[] { 1, 2 };
        numbers[1] = new int[] { 3, 4, 5 };
        numbers[2] = new int[] { 6, 7, 8, 9 };

        for (int i = 0; i < numbers.Length; i++)
        {
            for (int j = 0; j < numbers[i].Length; j++)
            {
                Console.Write(numbers[i][j] + " ");
            }
            Console.WriteLine();
        }
    }
}
